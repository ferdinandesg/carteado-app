{
  "name": "carteado-app",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "prepare": "husky install",
    "postinstall": "npm run prisma:generate -w backend",
    "format": "prettier --write .",
    "precommit": "lint-staged -p false -q -r",
    "clean": "git clean -fdX -- ./backend/dist ./frontend/.next ./frontend/out ./shared/dist || exit 0",
    "build": "npm run build:shared && npm run build -w backend && npm run build -w frontend",
    "build:shared": "npm run build -w shared",
    "lint": "eslint -c eslint.node.mjs backend/src shared && eslint -c frontend/eslint.config.mjs frontend/src",
    "typecheck": "npm run ts-check -ws --if-present",
    "check": "npm run build:shared && npm run lint && npm run typecheck",
    "validate": "npm run check && npm run test && npm run build -w backend && npm run build -w frontend",
    "validate:ci": "npm run check && npm run test -- --ci --coverage && npm run build -w backend && npm run build -w frontend",
    "dev": "concurrently -k -n shared,backend,frontend -c magenta,blue,green \"npm run dev -w shared\" \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:shared": "npm run dev -w shared",
    "dev:safe": "npm run validate && npm run dev",
    "test": "jest",
    "deploy:dev": "docker compose -f docker/compose.dev.yml up --build",
    "dev:services": "docker compose -f docker/compose.dev.services.yml up -d",
    "dev:services:down": "docker compose -f docker/compose.dev.services.yml down",
    "deploy:prod": "docker compose -f deploy/docker-compose-prod.yml up --build",
    "deploy:prod:local": "npm run build && docker compose -f deploy/docker-compose.prod.local.yml up --build",
    "deploy:prod:env": "node scripts/prepare-deploy-env.js",
    "deploy:prod:send": "scp -i ~/.ssh/id_ed25519 -r deploy/ franmlfran@34.10.106.241:/home/franmlfran/",
    "deploy:prod:up": "ssh -i ~/.ssh/id_ed25519 franmlfran@34.10.106.241 \"cd /home/franmlfran/deploy && docker compose -f docker-compose-prod.yml pull && docker compose -f docker-compose-prod.yml up -d\"",
    "deploy:prod:manual": "npm run deploy:prod:env && npm run deploy:prod:send && npm run deploy:prod:up",
    "ssh": "ssh -i ~/.ssh/id_ed25519 franmlfran@34.10.106.241",
    "ssh:tunnel": "ssh -i ~/.ssh/id_ed25519 -L 27017:localhost:27017 franmlfran@34.10.106.241"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --write",
    "backend/src/**/*.ts": [
      "prettier --write",
      "eslint -c eslint.node.mjs --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint -c frontend/eslint.config.mjs --fix"
    ],
    "shared/**/*.ts": [
      "prettier --write",
      "eslint -c eslint.node.mjs --fix",
      "node scripts/staged-shared-check.mjs"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.4",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.4.1",
    "bufferutil": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.60.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-mock-extended": "^4.0.1",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "utf-8-validate": "^6.0.6"
  }
}
