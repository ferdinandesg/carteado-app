# npm run deploy:prod:env gera deploy/.env a partir do .env da raiz.
# O CI também cria .env no servidor a cada deploy.

GOOGLE_ID=
GOOGLE_SECRET=
NEXTAUTH_URL=https://carteado.ferdinandes.com.br
NEXTAUTH_SECRET=
# URL interna no Docker. Usuário/senha devem ser os mesmos do Mongo (volume existente ignora MONGO_INITDB_*).
# Se o Prisma falhar com "SCRAM failure: Authentication failed", a senha no Mongo não bate com esta URL.
# Incluir directConnection=true ajuda o driver com replica set de 1 nó (Docker).
# Caracteres especiais na senha devem estar percent-encoded na URL (ex.: @ → %40).
DATABASE_URL=mongodb://root:password@mongodb:27017/carteado?replicaSet=rs0&authSource=admin&directConnection=true
JWT_SECRET_KEY=
APP_VERSION=latest
