# npm run deploy:prod:env gera deploy/.env a partir do .env da raiz.
# O CI também cria .env no servidor a cada deploy.

GOOGLE_ID=
GOOGLE_SECRET=
NEXTAUTH_URL=https://carteado.ferdinandes.com.br
NEXTAUTH_SECRET=
# URL interna no Docker (deve bater com user/senha do serviço mongodb em docker-compose-prod)
DATABASE_URL=mongodb://root:password@mongodb:27017/carteado?replicaSet=rs0&authSource=admin
JWT_SECRET_KEY=
APP_VERSION=latest
