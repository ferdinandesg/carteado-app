# Raiz – docker-compose e dev local (copie para .env)

# Backend assina/valida accessToken (HTTP + socket)
JWT_SECRET_KEY=replace_with_long_random_string
# Sessão/cookie do NextAuth (não é o JWT da API)
NEXTAUTH_SECRET=replace_with_long_random_string
GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_SECRET=your_google_client_secret

# Dev local (app no host, npm run dev)
NEXTAUTH_URL=http://localhost:3000
API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
